# Staging-stack .env deltas (#223). Copy ~/LFG/.env to ~/LFG-staging/.env,
# then apply these overrides. Everything not listed stays identical to prod
# (same XUMM app, same Bunny zone).

XRPL_NETWORK=testnet
ECONOMY_ENABLED=1
WEBAPP_PORT=8177
LFG_SERVICE_URL=http://localhost:8177

# WARNING: staging shares prod's Bunny CDN zone. Testnet edition numbers
# overlap mainnet's, so without these overrides staging uploads would
# overwrite mainnet CDN objects at the same path. Keep staging on its own
# folders:
BUNNY_CDN_FOLDER=staging-mints
SWAP_CDN_FOLDER=LFGO-staging
ECONOMY_CDN_FOLDER=LFGO-staging

# Staging surfaces — create a separate Discord app (+ test-guild install)
# and a separate BotFather bot; until these are filled, keep stg-bot and
# stg-telegram stopped (pm2 stop stg-bot stg-telegram).
DISCORD_BOT_TOKEN=<staging discord bot token>
DISCORD_GUILD_ID=<test guild id>
ADMIN_LOG_CHANNEL_ID=<test guild admin channel>
TELEGRAM_BOT_TOKEN=<staging telegram bot token>
TELEGRAM_ANNOUNCE_CHAT_ID=<staging telegram channel>
# Distinct service tokens so a leaked staging token grants nothing on prod:
SERVICE_TOKEN_DISCORD=<new random value: openssl rand -hex 32>
SERVICE_TOKEN_TELEGRAM=<new random value: openssl rand -hex 32>

# Mini App / Activity ingress for staging (second Funnel route):
TELEGRAM_MINI_APP_URL=<staging public https url, path /lfg-staging>

# X auto-poster (#41) — staging stays off by default; only fill in if
# smoke-testing the poster against a throwaway/staging X app so a leaked
# staging cred can't post to the real brand account.
X_ENABLED=0
X_CONSUMER_KEY=<staging x app consumer key, if smoke-testing>
X_CONSUMER_SECRET=<staging x app consumer secret, if smoke-testing>
X_ACCESS_TOKEN=<staging x account access token, if smoke-testing>
X_ACCESS_SECRET=<staging x account access secret, if smoke-testing>
SERVICE_TOKEN_X=<new random value: openssl rand -hex 32>
X_MONTHLY_POST_BUDGET=10
X_STATE_DB_PATH=x_state_staging.db
PUBLIC_SHARE_BASE_URL=<staging public https base, if testing share links>
